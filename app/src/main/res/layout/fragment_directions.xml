<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="8dp">

    <TextView android:id="@+id/tvRouteTitle"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="20sp" android:textStyle="bold" android:padding="12dp"
        android:accessibilityHeading="true"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Изберете направление:" android:textSize="15sp"
        android:paddingHorizontal="12dp" android:paddingBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvDirections"
        android:layout_width="match_parent" android:layout_height="match_parent"/>
</LinearLayout>