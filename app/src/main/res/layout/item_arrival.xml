<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:paddingVertical="12dp"
    android:paddingHorizontal="4dp" android:minHeight="56dp"
    android:gravity="center_vertical">

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvRoute"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="16sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvHeadsign"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="14sp" android:alpha="0.8" android:layout_marginTop="2dp"/>
    </LinearLayout>

    <TextView android:id="@+id/tvTimes"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="15sp" android:textStyle="bold" android:textColor="#388E3C"/>
</LinearLayout>