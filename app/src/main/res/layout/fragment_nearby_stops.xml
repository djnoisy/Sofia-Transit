<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Спирки около вас"
            android:textSize="22sp"
            android:textStyle="bold"
            android:accessibilityHeading="true"/>

        <Button android:id="@+id/btnDiagnostics"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Диагностика"
            android:contentDescription="Отвори диагностика на API"
            style="@style/Widget.Material3.Button.TextButton"/>
    </LinearLayout>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Най-близките спирки в 4 посоки (12, 3, 6 и 9 часа). Натиснете спирка за разписание."
        android:textSize="14sp" android:paddingBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvClockStops"
        android:layout_width="match_parent" android:layout_height="match_parent"/>
</LinearLayout>
